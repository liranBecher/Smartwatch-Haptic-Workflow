        "jsCode": "const params = $('Execute Workflow Trigger').first().json.params;\nconst session_id = $('Execute Workflow Trigger').first().json.session_id;\nlet message = `🗑️ All parameters for the use case **${params.usecase_name}** have been removed.`;\nreturn [{ json: { reply: message, session_id }}];"
      },
