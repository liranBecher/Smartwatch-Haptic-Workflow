    {
      "parameters": {
        "jsCode": "const action = $('Execute Workflow Trigger').first().json.action;\nconst params = $('Execute Workflow Trigger').first().json.params;\nconst session_id = $('Execute Workflow Trigger').first().json.session_id;\n\nlet message = \"\";\nif (action === 'remove_usecase') {\n  message = `🗑️ All parameters for the use case **${params.usecase_name}** have been removed.`;\n} else {\n  message = `🗑️ Parameter ID **${params.id}** has been deleted from the dictionary.`;\n}\n\nreturn [{ json: { reply: message, session_id }}];"
      },
