    {
      "parameters": {
        "jsCode": "// Get all incoming items\nconst items = $input.all();\nconst session_id = $('Execute Workflow Trigger').first().json.session_id;\n\n// Check if the first item is empty (no keys) or if there are no items\nconst isEmpty = items.length === 0 || Object.keys(items[0].json).length === 0;\n\nif (isEmpty) {\n  return [{ json: {\n    reply: \"The use case dictionary is currently empty.\",\n    session_id\n  }}];\n}\n\nconst rows = items.map(i => i.json);\n\n// Group parameters by use case name\nconst grouped = rows.reduce((acc, row) => {\n  if (!acc[row.usecase_name]) acc[row.usecase_name] = [];\n  acc[row.usecase_name].push(`   ID${row.dict_entry} ${row.usecase_parameter_name} (${row.parameter_format})${row.is_required ? ' [Required]' : ''}`);\n  return acc;\n}, {});\n\nconst lines = Object.keys(grouped).map(name => \n  `📂 **${name}**\\n${grouped[name].join('\\n')}`\n).join('\\n\\n');\n\nreturn [{ json: {\n  reply: `Here are the available use cases and their parameters:\\n\\n${lines}`,\n  session_id\n}}];"
      },
      "id": "7df01906-dd26-4b82-ace8-ef1a50ba1fa0",
      "name": "Format Dict List",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1584,
        560
      ]
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst session_id = $('Execute Workflow Trigger').first().json.session_id;\n\nreturn [{ json: {\n  reply: `✅ Successfully added parameter **${rows[0].usecase_parameter_name}** to the **${rows[0].usecase_name}** use case (ID: ${rows[0].dict_entry}).`,\n  session_id\n}}];"
      },
      "id": "496463c5-af31-46de-a84d-475a9ead6865",
