        "query": "UPDATE public.\"UseCaseDictionary\" \nSET usecase_name = COALESCE($2, usecase_name), \n    parameter_name = COALESCE($3, parameter_name), \n    parameter_format = COALESCE($4, parameter_format) \nWHERE id = $1 RETURNING *;",
