    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO \"UseCaseDictionary\" (usecase_name, usecase_parameter_name, parameter_format, is_required, description) \nVALUES ($1, $2, $3, $4, $5) RETURNING *;",
        "options": {
          "queryReplacement": "={{ $json.params.usecase_name }}, {{ $json.params.usecase_parameter_name }}, {{ $json.params.parameter_format }}, {{ $json.params.is_required }}, {{ $json.params.description||null }}"
        }
      },
