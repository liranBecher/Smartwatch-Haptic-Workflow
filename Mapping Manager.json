    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  ROUND(MIN(sd.value)::numeric, 2) AS min_seen,\n  ROUND(MAX(sd.value)::numeric, 2) AS max_seen,\n  ROUND(AVG(sd.value)::numeric, 2) AS avg_seen,\n  COUNT(*) AS total_readings\nFROM \"SensorData\" sd\nJOIN \"UseCase\" st ON sd.usecase_id = st.usecase_id\nWHERE st.name = $1\n  AND sd.time > NOW() - INTERVAL '30 days';",
        "options": {
          "queryReplacement": "=={{ $json.usecase_name }}"
        }
      },
