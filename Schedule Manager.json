    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst name = $('Execute Workflow Trigger').first().json.usecase_name;\nconst session_id = $('Execute Workflow Trigger').first().json.session_id;\n\nif (rows.length === 0) {\n  return [{ json: {\n    reply: `No active schedules found for ${name}.`,\n    session_id\n  }}];\n}\n\nconst lines = rows.map(r => \n  `• ID ${r.schedule_id}: Every ${r.interval_days} days (Type: ${r.measure_type}) - Next run: ${r.next_run_date || 'N/A'}`\n).join('\\n');\n\nreturn [{ json: {\n  reply: `Active schedules for ${name} (${rows.length} total):\\n\\n${lines}`,\n  session_id\n}}];"
      },
