    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst session_id = $('Execute Workflow Trigger').first().json.session_id;\n\nif (rows.length === 0) {\n  return [{ json: { reply: \"Update failed. Schedule ID not found.\", session_id }}];\n}\n\nreturn [{ json: {\n  reply: `✅ Updated schedule ${rows[0].schedule_id}. User: ${rows[0].user_id} ,interval: ${rows[0].interval_days} days, measure: ${rows[0].measure_type}, trigger percentage: ${rows[0].trigger_percentage}.`,\n  session_id\n}}];"
      },
