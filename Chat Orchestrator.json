      "parameters": {
        "jsCode": "const raw = ($input.first().json.text ?? '')\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/\\s*```$/i, '')\n  .trim();\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch(e) {\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n}\n\nconst validIntents = ['mapping', 'knowledge', 'api_fetch', 'personalization', 'clarify'];\nif (!validIntents.includes(parsed.intent)) {\n  parsed.intent = 'clarify';\n}\n\nreturn [{\n  json: {\n    intent:      parsed.intent,\n    reply:       parsed.reply,\n    payload:     parsed.payload ?? {},\n    session_id:  $('Build prompt').first().json.session_id,\n    message:     $('Build prompt').first().json.message,\n    history:     $('Build prompt').first().json.history,\n    usecase_id:  $('Build prompt').first().json.usecase_id,\n    usecase_name: $('Build prompt').first().json.usecase_name,\n  }\n}];"
